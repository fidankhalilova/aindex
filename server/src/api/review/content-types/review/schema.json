{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Review"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "rating": {
      "type": "integer",
      "required": true,
      "min": 0,
      "max": 5
    },
    "title": {
      "type": "string",
      "required": true
    },
    "content": {
      "type": "text",
      "required": true
    },
    "pros": {
      "type": "text"
    },
    "cons": {
      "type": "text"
    },
    "isVerified": {
      "type": "boolean",
      "default": false
    },
    "helpful": {
      "type": "integer",
      "default": 0
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "reviews"
    },
    "tool": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tool.tool",
      "inversedBy": "reviews"
    }
  }
}
