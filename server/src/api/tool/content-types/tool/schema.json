{
  "kind": "collectionType",
  "collectionName": "tools",
  "info": {
    "singularName": "tool",
    "pluralName": "tools",
    "displayName": "Tool"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "shortDescription": {
      "type": "text",
      "maxLength": 160,
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "website": {
      "type": "string",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "screenshots": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "pricing": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Free",
        "Freemium",
        "Paid",
        "Enterprise"
      ]
    },
    "pricingDetails": {
      "type": "text"
    },
    "averageRating": {
      "type": "decimal",
      "required": false,
      "default": 0,
      "min": 0,
      "max": 5
    },
    "reviewsCount": {
      "type": "integer",
      "default": 0
    },
    "viewsCount": {
      "type": "integer",
      "default": 0
    },
    "isVerified": {
      "type": "boolean",
      "default": false
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "state": {
      "type": "enumeration",
      "default": "Draft",
      "enum": [
        "Draft",
        "Published",
        "Rejected"
      ]
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "tool"
    },
    "submittedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "tools"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "tool"
    },
    "tags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag.tag",
      "mappedBy": "tool"
    },
    "features": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::feature.feature",
      "mappedBy": "tool"
    }
  }
}
